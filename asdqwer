<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>스마트 To-Do List</title>
    <style>
        :root {
            --primary: #6c5ce7;
            --primary-light: #a29bfe;
            --primary-dark: #5b4cdb;
            --accent: #00cec9;
            --danger: #ff7675;
            --warning: #fdcb6e;
            --success: #00b894;
            --bg: #0f0f1a;
            --bg-card: #1a1a2e;
            --bg-input: #16213e;
            --text: #e0e0e0;
            --text-dim: #888;
            --border: #2a2a4a;
            --shadow: rgba(0, 0, 0, 0.3);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Apple SD Gothic Neo', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        .app-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            text-align: center;
            padding: 30px 0 20px;
        }

        header h1 {
            font-size: 2.2rem;
            background: linear-gradient(135deg, var(--primary-light), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

        header p {
            color: var(--text-dim);
            font-size: 0.95rem;
        }

        .stats-bar {
            display: flex;
            gap: 15px;
            margin-bottom: 25px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 15px 25px;
            text-align: center;
            min-width: 140px;
            transition: transform 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
        }

        .stat-card .stat-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary-light);
        }

        .stat-card .stat-label {
            font-size: 0.8rem;
            color: var(--text-dim);
            margin-top: 4px;
        }

        .stat-card.completed .stat-value { color: var(--success); }
        .stat-card.pending .stat-value { color: var(--warning); }
        .stat-card.overdue .stat-value { color: var(--danger); }

        .main-layout {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 25px;
        }

        @media (max-width: 768px) {
            .main-layout {
                grid-template-columns: 1fr;
            }
        }

        .sidebar {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            height: fit-content;
            position: sticky;
            top: 20px;
        }

        .sidebar h3 {
            font-size: 1rem;
            color: var(--primary-light);
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter-group {
            margin-bottom: 20px;
        }

        .filter-group label {
            display: block;
            font-size: 0.85rem;
            color: var(--text-dim);
            margin-bottom: 6px;
        }

        .filter-group select,
        .filter-group input {
            width: 100%;
            padding: 10px 12px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .filter-group select:focus,
        .filter-group input:focus {
            border-color: var(--primary);
        }

        .day-selector {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
            margin-top: 6px;
        }

        .day-btn {
            padding: 8px 4px;
            border: 1px solid var(--border);
            background: var(--bg-input);
            color: var(--text-dim);
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.75rem;
            text-align: center;
            transition: all 0.2s;
        }

        .day-btn:hover {
            border-color: var(--primary);
            color: var(--text);
        }

        .day-btn.active {
            background: var(--primary);
            border-color: var(--primary);
            color: white;
        }

        .time-range {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .time-range span {
            color: var(--text-dim);
            font-size: 0.85rem;
        }

        .time-range input[type="time"] {
            flex: 1;
        }

        .priority-filter {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .priority-btn {
            padding: 6px 12px;
            border: 1px solid var(--border);
            background: var(--bg-input);
            color: var(--text-dim);
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.8rem;
            transition: all 0.2s;
        }

        .priority-btn:hover { border-color: var(--primary); }
        .priority-btn.active { color: white; }
        .priority-btn.active[data-priority="all"] { background: var(--primary); border-color: var(--primary); }
        .priority-btn.active[data-priority="high"] { background: var(--danger); border-color: var(--danger); }
        .priority-btn.active[data-priority="medium"] { background: var(--warning); border-color: var(--warning); color: #333; }
        .priority-btn.active[data-priority="low"] { background: var(--success); border-color: var(--success); }

        .category-filter {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .cat-btn {
            padding: 5px 10px;
            border: 1px solid var(--border);
            background: var(--bg-input);
            color: var(--text-dim);
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.78rem;
            transition: all 0.2s;
        }

        .cat-btn:hover { border-color: var(--primary); color: var(--text); }
        .cat-btn.active { background: var(--primary); border-color: var(--primary); color: white; }

        .filter-actions {
            display: flex;
            gap: 8px;
        }

        .btn-reset {
            flex: 1;
            padding: 10px;
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-dim);
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .btn-reset:hover {
            border-color: var(--danger);
            color: var(--danger);
        }

        .main-content {
            min-width: 0;
        }

        .add-todo-section {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .add-todo-section h3 {
            font-size: 1rem;
            color: var(--primary-light);
            margin-bottom: 15px;
        }

        .add-form-row {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .add-form-row input,
        .add-form-row select,
        .add-form-row textarea {
            padding: 10px 12px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .add-form-row input:focus,
        .add-form-row select:focus,
        .add-form-row textarea:focus {
            border-color: var(--primary);
        }

        .add-form-row .input-title {
            flex: 1;
            min-width: 200px;
        }

        .add-form-row textarea {
            width: 100%;
            min-height: 60px;
            resize: vertical;
            font-family: inherit;
        }

        .recurring-options {
            display: none;
            padding: 10px;
            background: var(--bg-input);
            border-radius: 8px;
            margin-bottom: 10px;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        .recurring-options.show {
            display: flex;
        }

        .recurring-options label {
            font-size: 0.85rem;
            color: var(--text-dim);
        }

        .recurring-options select, .recurring-options input {
            padding: 6px 10px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text);
            font-size: 0.85rem;
        }

        .btn-add {
            padding: 10px 30px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 0.95rem;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.1s;
            font-weight: 600;
        }

        .btn-add:hover { opacity: 0.9; }
        .btn-add:active { transform: scale(0.98); }

        .search-sort-bar {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }

        .search-input {
            flex: 1;
            min-width: 200px;
            padding: 10px 15px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: 0.9rem;
            outline: none;
        }

        .search-input:focus { border-color: var(--primary); }

        .sort-select {
            padding: 10px 15px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: 0.9rem;
            outline: none;
        }

        .view-toggle {
            display: flex;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
        }

        .view-btn {
            padding: 10px 15px;
            background: var(--bg-card);
            border: none;
            color: var(--text-dim);
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .view-btn.active {
            background: var(--primary);
            color: white;
        }

        .todo-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .todo-item {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 15px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            transition: all 0.3s;
            animation: slideIn 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .todo-item::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 4px;
        }

        .todo-item.priority-high::before { background: var(--danger); }
        .todo-item.priority-medium::before { background: var(--warning); }
        .todo-item.priority-low::before { background: var(--success); }

        .todo-item.completed {
            opacity: 0.5;
        }

        .todo-item.completed .todo-title {
            text-decoration: line-through;
        }

        .todo-item.overdue {
            border-color: rgba(255, 118, 117, 0.3);
        }

        .todo-checkbox {
            width: 22px;
            height: 22px;
            border: 2px solid var(--border);
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.2s;
            margin-top: 2px;
        }

        .todo-checkbox:hover {
            border-color: var(--primary);
        }

        .todo-checkbox.checked {
            background: var(--success);
            border-color: var(--success);
        }

        .todo-checkbox.checked::after {
            content: '✓';
            color: white;
            font-size: 0.8rem;
            font-weight: bold;
        }

        .todo-body {
            flex: 1;
            min-width: 0;
        }

        .todo-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 4px;
            word-break: break-word;
        }

        .todo-desc {
            font-size: 0.85rem;
            color: var(--text-dim);
            margin-bottom: 8px;
            word-break: break-word;
        }

        .todo-meta {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        .todo-tag {
            font-size: 0.75rem;
            padding: 3px 8px;
            border-radius: 12px;
            background: rgba(108, 92, 231, 0.2);
            color: var(--primary-light);
        }

        .todo-tag.date-tag {
            background: rgba(0, 206, 201, 0.15);
            color: var(--accent);
        }

        .todo-tag.time-tag {
            background: rgba(253, 203, 110, 0.15);
            color: var(--warning);
        }

        .todo-tag.category-tag {
            background: rgba(0, 184, 148, 0.15);
            color: var(--success);
        }

        .todo-tag.overdue-tag {
            background: rgba(255, 118, 117, 0.2);
            color: var(--danger);
        }

        .todo-tag.recurring-tag {
            background: rgba(108, 92, 231, 0.15);
            color: var(--primary-light);
        }

        .subtask-list {
            margin-top: 8px;
            padding-left: 5px;
        }

        .subtask-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 4px 0;
            font-size: 0.85rem;
            color: var(--text-dim);
        }

        .subtask-item .sub-check {
            width: 16px;
            height: 16px;
            border: 1.5px solid var(--border);
            border-radius: 3px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 0.65rem;
            transition: all 0.2s;
        }

        .subtask-item .sub-check.checked {
            background: var(--success);
            border-color: var(--success);
            color: white;
        }

        .subtask-item .sub-check.checked::after {
            content: '✓';
        }

        .subtask-item.done .sub-text {
            text-decoration: line-through;
            opacity: 0.6;
        }

        .subtask-add {
            display: flex;
            gap: 6px;
            margin-top: 6px;
        }

        .subtask-add input {
            flex: 1;
            padding: 5px 8px;
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 5px;
            color: var(--text);
            font-size: 0.8rem;
            outline: none;
        }

        .subtask-add button {
            padding: 5px 10px;
            background: var(--primary);
            border: none;
            border-radius: 5px;
            color: white;
            cursor: pointer;
            font-size: 0.8rem;
        }

        .todo-actions {
            display: flex;
            gap: 6px;
            flex-shrink: 0;
        }

        .todo-actions button {
            width: 32px;
            height: 32px;
            border: 1px solid var(--border);
            background: var(--bg-input);
            color: var(--text-dim);
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .todo-actions button:hover {
            border-color: var(--primary);
            color: var(--text);
        }

        .todo-actions .btn-delete:hover {
            border-color: var(--danger);
            color: var(--danger);
        }

        .progress-bar-container {
            width: 100%;
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            margin-top: 8px;
        }

        .progress-bar-fill {
            height: 100%;
            background: var(--success);
            border-radius: 2px;
            transition: width 0.3s;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--text-dim);
        }

        .empty-state .empty-icon {
            font-size: 3rem;
            margin-bottom: 15px;
        }

        .calendar-view {
            display: none;
        }

        .calendar-view.active {
            display: block;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 4px;
        }

        .calendar-header-cell {
            text-align: center;
            padding: 8px;
            font-size: 0.8rem;
            color: var(--text-dim);
            font-weight: 600;
        }

        .calendar-cell {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px;
            min-height: 80px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .calendar-cell:hover {
            border-color: var(--primary);
        }

        .calendar-cell.today {
            border-color: var(--accent);
        }

        .calendar-cell.other-month {
            opacity: 0.3;
        }

        .calendar-cell .cell-date {
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .calendar-cell .cell-todos {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .calendar-cell .cell-todo-dot {
            font-size: 0.65rem;
            padding: 2px 4px;
            border-radius: 3px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .calendar-cell .cell-todo-dot.high { background: rgba(255,118,117,0.2); color: var(--danger); }
        .calendar-cell .cell-todo-dot.medium { background: rgba(253,203,110,0.2); color: var(--warning); }
        .calendar-cell .cell-todo-dot.low { background: rgba(0,184,148,0.2); color: var(--success); }

        .calendar-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .calendar-nav button {
            padding: 8px 15px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            cursor: pointer;
            transition: all 0.2s;
        }

        .calendar-nav button:hover {
            border-color: var(--primary);
        }

        .calendar-nav h3 {
            font-size: 1.1rem;
        }

        .list-view.active {
            display: flex;
        }

        .list-view {
            display: none;
            flex-direction: column;
            gap: 10px;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.6);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 25px;
            max-width: 500px;
            width: 100%;
            max-height: 80vh;
            overflow-y: auto;
        }

        .modal h3 {
            color: var(--primary-light);
            margin-bottom: 15px;
        }

        .modal .add-form-row {
            flex-direction: column;
        }

        .modal .add-form-row input,
        .modal .add-form-row select,
        .modal .add-form-row textarea {
            width: 100%;
        }

        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            justify-content: flex-end;
        }

        .modal-actions button {
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9rem;
            border: 1px solid var(--border);
            transition: all 0.2s;
        }

        .modal-actions .btn-save {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .modal-actions .btn-cancel {
            background: transparent;
            color: var(--text-dim);
        }

        .export-import-bar {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
            margin-bottom: 15px;
            flex-wrap: wrap;
        }

        .export-import-bar button {
            padding: 8px 15px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-dim);
            cursor: pointer;
            font-size: 0.8rem;
            transition: all 0.2s;
        }

        .export-import-bar button:hover {
            border-color: var(--primary);
            color: var(--text);
        }

        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            padding: 12px 24px;
            background: var(--bg-card);
            border: 1px solid var(--primary);
            border-radius: 10px;
            color: var(--text);
            font-size: 0.9rem;
            z-index: 2000;
            animation: toastIn 0.3s ease, toastOut 0.3s ease 2.7s forwards;
            box-shadow: 0 4px 20px var(--shadow);
        }

        @keyframes toastIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes toastOut {
            from { opacity: 1; }
            to { opacity: 0; }
        }

        .pomodoro-widget {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            margin-top: 20px;
        }

        .pomodoro-widget h3 {
            font-size: 1rem;
            color: var(--primary-light);
            margin-bottom: 10px;
        }

        .pomodoro-display {
            font-size: 2.5rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            margin-bottom: 15px;
            color: var(--accent);
        }

        .pomodoro-controls {
            display: flex;
            gap: 8px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .pomodoro-controls button {
            padding: 8px 16px;
            border: 1px solid var(--border);
            background: var(--bg-input);
            color: var(--text);
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.2s;
        }

        .pomodoro-controls button:hover {
            border-color: var(--primary);
        }

        .pomodoro-controls button.active-timer {
            background: var(--danger);
            border-color: var(--danger);
        }

        .date-group-header {
            font-size: 0.9rem;
            color: var(--primary-light);
            padding: 10px 0 5px;
            border-bottom: 1px solid var(--border);
            margin-bottom: 5px;
            font-weight: 600;
        }

        .drag-over {
            border-color: var(--primary) !important;
            background: rgba(108, 92, 231, 0.05);
        }

        .checkbox-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
        }

        .checkbox-row input[type="checkbox"] {
            accent-color: var(--primary);
            width: 16px;
            height: 16px;
        }

        .checkbox-row label {
            font-size: 0.85rem;
            color: var(--text-dim);
        }

        .kanban-view {
            display: none;
        }

        .kanban-view.active {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
        }

        @media (max-width: 768px) {
            .kanban-view.active {
                grid-template-columns: 1fr;
            }
        }

        .kanban-column {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 15px;
        }

        .kanban-column h4 {
            font-size: 0.9rem;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--border);
        }

        .kanban-column .kanban-items {
            display: flex;
            flex-direction: column;
            gap: 8px;
            min-height: 50px;
        }

        .kanban-card {
            background: var(--bg-input);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .kanban-card:hover {
            border-color: var(--primary);
        }

        .kanban-card .k-title {
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .kanban-card .k-meta {
            font-size: 0.72rem;
            color: var(--text-dim);
        }

        .theme-toggle {
            position: fixed;
            top: 15px;
            right: 15px;
            z-index: 100;
            padding: 8px 12px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text);
            cursor: pointer;
            font-size: 1.1rem;
            transition: all 0.2s;
        }

        .theme-toggle:hover {
            border-color: var(--primary);
        }

        body.light {
            --bg: #f5f5fa;
            --bg-card: #ffffff;
            --bg-input: #f0f0f5;
            --text: #2d3436;
            --text-dim: #636e72;
            --border: #dfe6e9;
            --shadow: rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body>
    <button class="theme-toggle" onclick="toggleTheme()" title="테마 전환">🌓</button>

    <div class="app-container">
        <header>
            <h1>📋 스마트 To-Do List</h1>
            <p id="currentDateTime"></p>
        </header>

        <div class="stats-bar">
            <div class="stat-card">
                <div class="stat-value" id="totalCount">0</div>
                <div class="stat-label">전체</div>
            </div>
            <div class="stat-card completed">
                <div class="stat-value" id="completedCount">0</div>
                <div class="stat-label">완료</div>
            </div>
            <div class="stat-card pending">
                <div class="stat-value" id="pendingCount">0</div>
                <div class="stat-label">진행 중</div>
            </div>
            <div class="stat-card overdue">
                <div class="stat-value" id="overdueCount">0</div>
                <div class="stat-label">기한 초과</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="completionRate">0%</div>
                <div class="stat-label">완료율</div>
            </div>
        </div>

        <div class="main-layout">
            <aside class="sidebar">
                <h3>🔍 필터 및 탐색</h3>

                <div class="filter-group">
                    <label>📅 연도</label>
                    <select id="filterYear" onchange="applyFilters()">
                        <option value="all">전체 연도</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>📆 월</label>
                    <select id="filterMonth" onchange="applyFilters()">
                        <option value="all">전체</option>
                        <option value="0">1월</option>
                        <option value="1">2월</option>
                        <option value="2">3월</option>
                        <option value="3">4월</option>
                        <option value="4">5월</option>
                        <option value="5">6월</option>
                        <option value="6">7월</option>
                        <option value="7">8월</option>
                        <option value="8">9월</option>
                        <option value="9">10월</option>
                        <option value="10">11월</option>
                        <option value="11">12월</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>📅 요일</label>
                    <div class="day-selector">
                        <div class="day-btn active" data-day="all" onclick="toggleDay(this)">전체</div>
                        <div class="day-btn" data-day="0" onclick="toggleDay(this)">일</div>
                        <div class="day-btn" data-day="1" onclick="toggleDay(this)">월</div>
                        <div class="day-btn" data-day="2" onclick="toggleDay(this)">화</div>
                        <div class="day-btn" data-day="3" onclick="toggleDay(this)">수</div>
                        <div class="day-btn" data-day="4" onclick="toggleDay(this)">목</div>
                        <div class="day-btn" data-day="5" onclick="toggleDay(this)">금</div>
                        <div class="day-btn" data-day="6" onclick="toggleDay(this)">토</div>
                    </div>
                </div>

                <div class="filter-group">
                    <label>⏰ 시간대</label>
                    <div class="time-range">
                        <input type="time" id="filterTimeStart" onchange="applyFilters()">
                        <span>~</span>
                        <input type="time" id="filterTimeEnd" onchange="applyFilters()">
                    </div>
                </div>

                <div class="filter-group">
                    <label>🔴 우선순위</label>
                    <div class="priority-filter">
                        <div class="priority-btn active" data-priority="all" onclick="togglePriority(this)">전체</div>
                        <div class="priority-btn" data-priority="high" onclick="togglePriority(this)">높음</div>
                        <div class="priority-btn" data-priority="medium" onclick="togglePriority(this)">보통</div>
                        <div class="priority-btn" data-priority="low" onclick="togglePriority(this)">낮음</div>
                    </div>
                </div>

                <div class="filter-group">
                    <label>📁 카테고리</label>
                    <div class="category-filter" id="categoryFilter">
                        <div class="cat-btn active" data-cat="all" onclick="toggleCategory(this)">전체</div>
                        <div class="cat-btn" data-cat="업무" onclick="toggleCategory(this)">업무</div>
                        <div class="cat-btn" data-cat="개인" onclick="toggleCategory(this)">개인</div>
                        <div class="cat-btn" data-cat="학습" onclick="toggleCategory(this)">학습</div>
                        <div class="cat-btn" data-cat="건강" onclick="toggleCategory(this)">건강</div>
                        <div class="cat-btn" data-cat="기타" onclick="toggleCategory(this)">기타</div>
                    </div>
                </div>

                <div class="filter-group">
                    <label>📊 상태</label>
                    <select id="filterStatus" onchange="applyFilters()">
                        <option value="all">전체</option>
                        <option value="pending">진행 중</option>
                        <option value="completed">완료</option>
                        <option value="overdue">기한 초과</option>
                    </select>
                </div>

                <div class="filter-actions">
                    <button class="btn-reset" onclick="resetFilters()">🔄 필터 초기화</button>
                </div>

                <div class="pomodoro-widget">
                    <h3>🍅 포모도로 타이머</h3>
                    <div class="pomodoro-display" id="pomodoroDisplay">25:00</div>
                    <div class="pomodoro-controls">
                        <button onclick="startPomodoro()" id="pomodoroStartBtn">▶ 시작</button>
                        <button onclick="resetPomodoro()">⟳ 리셋</button>
                        <button onclick="setPomodoro(5)">☕ 휴식</button>
                        <button onclick="setPomodoro(25)">🍅 작업</button>
                    </div>
                </div>
            </aside>

            <div class="main-content">
                <div class="add-todo-section">
                    <h3>➕ 새 할 일 추가</h3>
                    <div class="add-form-row">
                        <input type="text" class="input-title" id="todoTitle" placeholder="할 일 제목..." onkeypress="if(event.key==='Enter')addTodo()">
                        <select id="todoPriority">
                            <option value="medium">보통</option>
                            <option value="high">높음</option>
                            <option value="low">낮음</option>
                        </select>
                        <select id="todoCategory">
                            <option value="업무">업무</option>
                            <option value="개인">개인</option>
                            <option value="학습">학습</option>
                            <option value="건강">건강</option>
                            <option value="기타">기타</option>
                        </select>
                    </div>
                    <div class="add-form-row">
                        <textarea id="todoDesc" placeholder="설명 (선택사항)..." rows="2"></textarea>
                    </div>
                    <div class="add-form-row">
                        <input type="date" id="todoDate">
                        <input type="time" id="todoTime">
                        <input type="date" id="todoDueDate" title="마감일">
                        <input type="time" id="todoDueTime" title="마감 시간">
                    </div>
                    <div class="checkbox-row">
                        <input type="checkbox" id="recurringCheck" onchange="document.querySelector('.recurring-options').classList.toggle('show', this.checked)">
                        <label for="recurringCheck">🔁 반복 일정</label>
                    </div>
                    <div class="recurring-options" id="recurringOptions">
                        <label>반복:</label>
                        <select id="recurringType">
                            <option value="daily">매일</option>
                            <option value="weekly">매주</option>
                            <option value="monthly">매월</option>
                        </select>
                        <label>종료:</label>
                        <input type="date" id="recurringEnd">
                    </div>
                    <div class="add-form-row" style="justify-content:flex-end;">
                        <button class="btn-add" onclick="addTodo()">추가하기</button>
                    </div>
                </div>

                <div class="export-import-bar">
                    <button onclick="exportData()">📤 내보내기 (JSON)</button>
                    <button onclick="document.getElementById('importFile').click()">📥 가져오기</button>
                    <input type="file" id="importFile" accept=".json" onchange="importData(event)" style="display:none">
                    <button onclick="exportCSV()">📊 CSV 내보내기</button>
                    <button onclick="clearCompleted()">🗑 완료 항목 삭제</button>
                </div>

                <div class="search-sort-bar">
                    <input type="text" class="search-input" id="searchInput" placeholder="🔍 검색..." oninput="applyFilters()">
                    <select class="sort-select" id="sortSelect" onchange="applyFilters()">
                        <option value="created-desc">최신순</option>
                        <option value="created-asc">오래된순</option>
                        <option value="date-asc">날짜 빠른순</option>
                        <option value="date-desc">날짜 느린순</option>
                        <option value="priority-desc">우선순위 높은순</option>
                        <option value="priority-asc">우선순위 낮은순</option>
                        <option value="alpha-asc">이름순 (A→Z)</option>
                        <option value="alpha-desc">이름순 (Z→A)</option>
                    </select>
                    <div class="view-toggle">
                        <button class="view-btn active" data-view="list" onclick="switchView('list')">📋 목록</button>
                        <button class="view-btn" data-view="calendar" onclick="switchView('calendar')">📅 캘린더</button>
                        <button class="view-btn" data-view="kanban" onclick="switchView('kanban')">📊 칸반</button>
                    </div>
                </div>

                <div class="list-view active" id="listView"></div>

                <div class="calendar-view" id="calendarView">
                    <div class="calendar-nav">
                        <button onclick="changeCalMonth(-1)">◀ 이전</button>
                        <h3 id="calMonthTitle"></h3>
                        <button onclick="changeCalMonth(1)">다음 ▶</button>
                    </div>
                    <div class="calendar-grid" id="calendarGrid"></div>
                </div>

                <div class="kanban-view" id="kanbanView">
                    <div class="kanban-column">
                        <h4>📝 할 일 (<span id="kanbanTodo">0</span>)</h4>
                        <div class="kanban-items" id="kanbanTodoItems"></div>
                    </div>
                    <div class="kanban-column">
                        <h4>🔄 진행 중 (<span id="kanbanProgress">0</span>)</h4>
                        <div class="kanban-items" id="kanbanProgressItems"></div>
                    </div>
                    <div class="kanban-column">
                        <h4>✅ 완료 (<span id="kanbanDone">0</span>)</h4>
                        <div class="kanban-items" id="kanbanDoneItems"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="editModal">
        <div class="modal">
            <h3>✏️ 할 일 수정</h3>
            <input type="hidden" id="editId">
            <div class="add-form-row">
                <label>제목</label>
                <input type="text" id="editTitle">
            </div>
            <div class="add-form-row">
                <label>설명</label>
                <textarea id="editDesc" rows="3"></textarea>
            </div>
            <div class="add-form-row">
                <label>날짜</label>
                <input type="date" id="editDate">
            </div>
            <div class="add-form-row">
                <label>시간</label>
                <input type="time" id="editTime">
            </div>
            <div class="add-form-row">
                <label>마감일</label>
                <input type="date" id="editDueDate">
            </div>
            <div class="add-form-row">
                <label>마감 시간</label>
                <input type="time" id="editDueTime">
            </div>
            <div class="add-form-row">
                <label>우선순위</label>
                <select id="editPriority">
                    <option value="high">높음</option>
                    <option value="medium">보통</option>
                    <option value="low">낮음</option>
                </select>
            </div>
            <div class="add-form-row">
                <label>카테고리</label>
                <select id="editCategory">
                    <option value="업무">업무</option>
                    <option value="개인">개인</option>
                    <option value="학습">학습</option>
                    <option value="건강">건강</option>
                    <option value="기타">기타</option>
                </select>
            </div>
            <div class="add-form-row">
                <label>칸반 상태</label>
                <select id="editKanban">
                    <option value="todo">할 일</option>
                    <option value="progress">진행 중</option>
                    <option value="done">완료</option>
                </select>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeEditModal()">취소</button>
                <button class="btn-save" onclick="saveEdit()">저장</button>
            </div>
        </div>
    </div>

    <script>
        let todos = JSON.parse(localStorage.getItem('smartTodos') || '[]');
        let currentView = 'list';
        let calDate = new Date();
        let pomodoroInterval = null;
        let pomodoroSeconds = 2 * 0;
        let selectedDays = ['all'];
        let selectedPriority = 'all';
        let selectedCategory = 'all';

        function init() {
            updateDateTime();
            setInterval(updateDateTime, 1000);
            populateYearFilter();
            const today = new Date();
            document.getElementById('todoDate').value = today.toISOString().split('T')[0];
            applyFilters();
            checkNotifications();
            setInterval(checkNotifications, 60000);
        }

        function updateDateTime() {
            const now = new Date();
            const days = ['일', '월', '화', '수', '목', '금', '토'];
            document.getElementById('currentDateTime').textContent =
                `<inlineMath>{now.getFullYear()}년 </inlineMath>{now.getMonth()+1}월 <inlineMath>{now.getDate()}일 (</inlineMath>{days[now.getDay()]}) \\({now.toLocaleTimeString('ko-KR')}`;
        }

        function populateYearFilter() {
            const select = document.getElementById('filterYear');
            const years = new Set();
            const currentYear = new Date().getFullYear();
            years.add(currentYear);
            todos.forEach(t => {
                if (t.date) years.add(new Date(t.date).getFullYear());
                if (t.dueDate) years.add(new Date(t.dueDate).getFullYear());
            });
            const sorted = [...years].sort((a,b) => b - a);
            select.innerHTML = '<option value="all">전체 연도</option>';
            sorted.forEach(y => {
                select.innerHTML += `<option value="\\){y}">\\({y}년</option>`;
            });
        }

        function generateId() {
            return Date.now().toString(36) + Math.random().toString(36).substr(2);
        }

        function saveTodos() {
            localStorage.setItem('smartTodos', JSON.stringify(todos));
            populateYearFilter();
            applyFilters();
        }

        function addTodo() {
            const title = document.getElementById('todoTitle').value.trim();
            if (!title) { showToast('⚠️ 제목을 입력하세요!'); return; }

            const isRecurring = document.getElementById('recurringCheck').checked;

            if (isRecurring) {
                addRecurringTodos(title);
            } else {
                const todo = createTodoObj(title);
                todos.push(todo);
            }

            document.getElementById('todoTitle').value = '';
            document.getElementById('todoDesc').value = '';
            document.getElementById('todoTime').value = '';
            document.getElementById('todoDueDate').value = '';
            document.getElementById('todoDueTime').value = '';
            document.getElementById('recurringCheck').checked = false;
            document.querySelector('.recurring-options').classList.remove('show');

            saveTodos();
            showToast('✅ 할 일이 추가되었습니다!');
        }

        function createTodoObj(title) {
            return {
                id: generateId(),
                title: title,
                desc: document.getElementById('todoDesc').value.trim(),
                date: document.getElementById('todoDate').value,
                time: document.getElementById('todoTime').value,
                dueDate: document.getElementById('todoDueDate').value,
                dueTime: document.getElementById('todoDueTime').value,
                priority: document.getElementById('todoPriority').value,
                category: document.getElementById('todoCategory').value,
                completed: false,
                kanban: 'todo',
                subtasks: [],
                createdAt: new Date().toISOString()
            };
        }

        function addRecurringTodos(title) {
            const type = document.getElementById('recurringType').value;
            const endDate = document.getElementById('recurringEnd').value;
            const startDate = document.getElementById('todoDate').value;

            if (!startDate || !endDate) { showToast('⚠️ 날짜를 설정하세요!'); return; }

            let current = new Date(startDate);
            const end = new Date(endDate);
            let count = 0;

            while (current <= end && count < 365) {
                const todo = createTodoObj(title);
                todo.date = current.toISOString().split('T')[0];
                todo.recurring = type;
                todos.push(todo);

                if (type === 'daily') current.setDate(current.getDate() + 1);
                else if (type === 'weekly') current.setDate(current.getDate() + 7);
                else if (type === 'monthly') current.setMonth(current.getMonth() + 1);
                count++;
            }

            showToast(`✅ \\){count}개 반복 일정이 추가되었습니다!`);
        }

        function toggleComplete(id) {
            const todo = todos.find(t => t.id === id);
            if (todo) {
                todo.completed = !todo.completed;
                todo.kanban = todo.completed ? 'done' : 'todo';
                todo.completedAt = todo.completed ? new Date().toISOString() : null;
                saveTodos();
            }
        }

        function deleteTodo(id) {
            if (confirm('정말 삭제하시겠습니까?')) {
                todos = todos.filter(t => t.id !== id);
                saveTodos();
                showToast('🗑 삭제되었습니다.');
            }
        }

        function openEditModal(id) {
            const todo = todos.find(t => t.id === id);
            if (!todo) return;
            document.getElementById('editId').value = id;
            document.getElementById('editTitle').value = todo.title;
            document.getElementById('editDesc').value = todo.desc || '';
            document.getElementById('editDate').value = todo.date || '';
            document.getElementById('editTime').value = todo.time || '';
            document.getElementById('editDueDate').value = todo.dueDate || '';
            document.getElementById('editDueTime').value = todo.dueTime || '';
            document.getElementById('editPriority').value = todo.priority;
            document.getElementById('editCategory').value = todo.category;
            document.getElementById('editKanban').value = todo.kanban || 'todo';
            document.getElementById('editModal').classList.add('active');
        }

        function closeEditModal() {
            document.getElementById('editModal').classList.remove('active');
        }

        function saveEdit() {
            const id = document.getElementById('editId').value;
            const todo = todos.find(t => t.id === id);
            if (!todo) return;

            todo.title = document.getElementById('editTitle').value.trim();
            todo.desc = document.getElementById('editDesc').value.trim();
            todo.date = document.getElementById('editDate').value;
            todo.time = document.getElementById('editTime').value;
            todo.dueDate = document.getElementById('editDueDate').value;
            todo.dueTime = document.getElementById('editDueTime').value;
            todo.priority = document.getElementById('editPriority').value;
            todo.category = document.getElementById('editCategory').value;
            todo.kanban = document.getElementById('editKanban').value;
            if (todo.kanban === 'done') {
                todo.completed = true;
                todo.completedAt = todo.completedAt || new Date().toISOString();
            } else {
                todo.completed = false;
                todo.completedAt = null;
            }

            closeEditModal();
            saveTodos();
            showToast('✏️ 수정 완료!');
        }

        function duplicateTodo(id) {
            const todo = todos.find(t => t.id === id);
            if (!todo) return;
            const dup = { ...todo, id: generateId(), completed: false, kanban: 'todo', completedAt: null, subtasks: [...(todo.subtasks || []).map(s => ({...s, done: false}))], createdAt: new Date().toISOString() };
            todos.push(dup);
            saveTodos();
            showToast('📋 복제되었습니다!');
        }

        function addSubtask(todoId) {
            const input = document.querySelector(`.subtask-input-\\({todoId}`);
            if (!input) return;
            const text = input.value.trim();
            if (!text) return;
            const todo = todos.find(t => t.id === todoId);
            if (!todo) return;
            if (!todo.subtasks) todo.subtasks = [];
            todo.subtasks.push({ id: generateId(), text, done: false });
            input.value = '';
            saveTodos();
        }

        function toggleSubtask(todoId, subId) {
            const todo = todos.find(t => t.id === todoId);
            if (!todo) return;
            const sub = todo.subtasks.find(s => s.id === subId);
            if (sub) {
                sub.done = !sub.done;
                saveTodos();
            }
        }

        function deleteSubtask(todoId, subId) {
            const todo = todos.find(t => t.id === todoId);
            if (!todo) return;
            todo.subtasks = todo.subtasks.filter(s => s.id !== subId);
            saveTodos();
        }

        function isOverdue(todo) {
            if (todo.completed) return false;
            if (!todo.dueDate) return false;
            const now = new Date();
            const due = new Date(todo.dueDate + (todo.dueTime ? 'T' + todo.dueTime : 'T23:59:59'));
            return now > due;
        }

        function getFilteredTodos() {
            let filtered = [...todos];
            const year = document.getElementById('filterYear').value;
            const month = document.getElementById('filterMonth').value;
            const timeStart = document.getElementById('filterTimeStart').value;
            const timeEnd = document.getElementById('filterTimeEnd').value;
            const status = document.getElementById('filterStatus').value;
            const search = document.getElementById('searchInput').value.toLowerCase().trim();

            if (year !== 'all') {
                filtered = filtered.filter(t => {
                    const d = t.date ? new Date(t.date).getFullYear() : null;
                    return d == year;
                });
            }

            if (month !== 'all') {
                filtered = filtered.filter(t => {
                    const d = t.date ? new Date(t.date).getMonth() : null;
                    return d == parseInt(month);
                });
            }

            if (!selectedDays.includes('all')) {
                filtered = filtered.filter(t => {
                    if (!t.date) return false;
                    const day = new Date(t.date).getDay();
                    return selectedDays.includes(day.toString());
                });
            }

            if (timeStart) {
                filtered = filtered.filter(t => !t.time || t.time >= timeStart);
            }
            if (timeEnd) {
                filtered = filtered.filter(t => !t.time || t.time <= timeEnd);
            }

            if (selectedPriority !== 'all') {
                filtered = filtered.filter(t => t.priority === selectedPriority);
            }

            if (selectedCategory !== 'all') {
                filtered = filtered.filter(t => t.category === selectedCategory);
            }

            if (status === 'completed') filtered = filtered.filter(t => t.completed);
            else if (status === 'pending') filtered = filtered.filter(t => !t.completed);
            else if (status === 'overdue') filtered = filtered.filter(t => isOverdue(t));

            if (search) {
                filtered = filtered.filter(t =>
                    t.title.toLowerCase().includes(search) ||
                    (t.desc && t.desc.toLowerCase().includes(search)) ||
                    t.category.toLowerCase().includes(search)
                );
            }

            const sort = document.getElementById('sortSelect').value;
            const priMap = { high: 3, medium: 2, low: 1 };

            filtered.sort((a, b) => {
                switch (sort) {
                    case 'created-desc': return new Date(b.createdAt) - new Date(a.createdAt);
                    case 'created-asc': return new Date(a.createdAt) - new Date(b.createdAt);
                    case 'date-asc': return (a.date || '9999') < (b.date || '9999') ? -1 : 1;
                    case 'date-desc': return (b.date || '0000') < (a.date || '0000') ? -1 : 1;
                    case 'priority-desc': return priMap[b.priority] - priMap[a.priority];
                    case 'priority-asc': return priMap[a.priority] - priMap[b.priority];
                    case 'alpha-asc': return a.title.localeCompare(b.title, 'ko');
                    case 'alpha-desc': return b.title.localeCompare(a.title, 'ko');
                    default: return 0;
                }
            });

            return filtered;
        }

        function applyFilters() {
            const filtered = getFilteredTodos();
            updateStats();

            if (currentView === 'list') renderListView(filtered);
            else if (currentView === 'calendar') renderCalendarView();
            else if (currentView === 'kanban') renderKanbanView(filtered);
        }

        function updateStats() {
            const total = todos.length;
            const completed = todos.filter(t => t.completed).length;
            const overdue = todos.filter(t => isOverdue(t)).length;
            const pending = total - completed;

            document.getElementById('totalCount').textContent = total;
            document.getElementById('completedCount').textContent = completed;
            document.getElementById('pendingCount').textContent = pending;
            document.getElementById('overdueCount').textContent = overdue;
            document.getElementById('completionRate').textContent = total > 0 ? Math.round(completed / tota * 00) + '%' : '0%';
        }

        function renderListView(filtered) {
            const container = document.getElementById('listView');
            if (filtered.length === 0) {
                container.innerHTML = `<div class="empty-state"><div class="empty-icon">📭</div><p>할 일이 없습니다.</p><p>위에서 새 할 일을 추가해보세요!</p></div>`;
                return;
            }

            let html = '';
            const dayNames = ['일', '월', '화', '수', '목', '금', '토'];

            filtered.forEach(todo => {
                const overdue = isOverdue(todo);
                const subProgress = todo.subtasks && todo.subtasks.length > 0 ?
                    todo.subtasks.filter(s => s.done).length / todo.subtasks.lengt * 00 : -1;

                let dateStr = '';
                if (todo.date) {
                    const d = new Date(todo.date);
                    dateStr = `\\){d.getFullYear()}.<inlineMath>{(d.getMonth()+1).toString().padStart(2,'0')}.</inlineMath>{d.getDate().toString().padStart(2,'0')} (\\({dayNames[d.getDay()]})`;
                }

                let dueStr = '';
                if (todo.dueDate) {
                    const d = new Date(todo.dueDate);
                    dueStr = `마감: \\){d.getFullYear()}.<inlineMath>{(d.getMonth()+1).toString().padStart(2,'0')}.</inlineMath>{d.getDate().toString().padStart(2,'0')}`;
                    if (todo.dueTime) dueStr += ` \\({todo.dueTime}`;
                }

                const priLabel = { high: '높음', medium: '보통', low: '낮음' };

                html += `
                <div class="todo-item priority-\\){todo.priority} <inlineMath>{todo.completed ? 'completed' : ''} </inlineMath>{overdue ? 'overdue' : ''}" draggable="true" ondragstart="onDragStart(event,'<inlineMath>{todo.id}')" ondragover="onDragOver(event)" ondrop="onDrop(event,'</inlineMath>{todo.id}')">
                    <div class="todo-checkbox <inlineMath>{todo.completed ? 'checked' : ''}" onclick="toggleComplete('</inlineMath>{todo.id}')"></div>
                    <div class="todo-body">
                        <div class="todo-title">\\({escapeHtml(todo.title)}</div>
                        \\){todo.desc ? `<div class="todo-desc">\\({escapeHtml(todo.desc)}</div>` : ''}
                        <div class="todo-meta">
                            <span class="todo-tag">\\){priLabel[todo.priority]}</span>
                            <span class="todo-tag category-tag">\\({escapeHtml(todo.category)}</span>
                            \\){dateStr ? `<span class="todo-tag date-tag">📅 \\({dateStr}</span>` : ''}
                            \\){todo.time ? `<span class="todo-tag time-tag">⏰ \\({todo.time}</span>` : ''}
                            \\){dueStr ? `<span class="todo-tag <inlineMath>{overdue ? 'overdue-tag' : 'date-tag'}"></inlineMath>{overdue ? '⚠️' : '🏁'} \\({dueStr}</span>` : ''}
                            \\){todo.recurring ? `<span class="todo-tag recurring-tag">🔁 반복</span>` : ''}
                        </div>
                        \\({subProgress >= 0 ? `
                        <div class="progress-bar-container">
                            <div class="progress-bar-fill" style="width:\\){subProgress}%"></div>
                        </div>` : ''}
                        \\({todo.subtasks && todo.subtasks.length > 0 ? `
                        <div class="subtask-list">
                            \\){todo.subtasks.map(s => `
                                <div class="subtask-item \\({s.done ? 'done' : ''}">
                                    <div class="sub-check \\){s.done ? 'checked' : ''}" onclick="toggleSubtask('\\({todo.id}','\\){s.id}')"></div>
                                    <span class="sub-text">\\({escapeHtml(s.text)}</span>
                                    <span style="cursor:pointer;color:var(--danger);font-size:0.75rem;" onclick="deleteSubtask('\\){todo.id}','\\({s.id}')">✕</span>
                                </div>
                            `).join('')}
                        </div>` : ''}
                        <div class="subtask-add">
                            <input type="text" class="subtask-input-\\){todo.id}" placeholder="하위 작업 추가..." onkeypress="if(event.key==='Enter')addSubtask('\\({todo.id}')">
                            <button onclick="addSubtask('\\){todo.id}')">+</button>
                        </div>
                    </div>
                    <div class="todo-actions">
                        <button onclick="openEditModal('\\({todo.id}')" title="수정">✏️</button>
                        <button onclick="duplicateTodo('\\){todo.id}')" title="복제">📋</button>
                        <button class="btn-delete" onclick="deleteTodo('\\({todo.id}')" title="삭제">🗑</button>
                    </div>
                </div>`;
            });

            container.innerHTML = html;
        }

        function renderCalendarView() {
            const grid = document.getElementById('calendarGrid');
            const year = calDate.getFullYear();
            const month = calDate.getMonth();

            document.getElementById('calMonthTitle').textContent = `\\){year}년 \\({month + 1}월`;

            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const today = new Date();

            const dayNames = ['일', '월', '화', '수', '목', '금', '토'];
            let html = dayNames.map(d => `<div class="calendar-header-cell">\\){d}</div>`).join('');

            const prevMonthDays = new Date(year, month, 0).getDate();
            for (let i = firstDay - 1; i >= 0; i--) {
                html += `<div class="calendar-cell other-month"><div class="cell-date">\\({prevMonthDays - i}</div></div>`;
            }

            for (let d = 1; d <= daysInMonth; d++) {
                const dateStr = `\\){year}-<inlineMath>{(month+1).toString().padStart(2,'0')}-</inlineMath>{d.toString().padStart(2,'0')}`;
                const isToday = today.getFullYear() === year && today.getMonth() === month && today.getDate() === d;
                const dayTodos = todos.filter(t => t.date === dateStr);

                html += `<div class="calendar-cell <inlineMath>{isToday ? 'today' : ''}" onclick="calendarDateClick('</inlineMath>{dateStr}')">
                    <div class="cell-date">\\({d}</div>
                    <div class="cell-todos">
                        \\){dayTodos.slice(0, 3).map(t => `<div class="cell-todo-dot \\({t.priority}" title="\\){escapeHtml(t.title)}"><inlineMath>{t.completed ? '✅' : '◻️'} </inlineMath>{escapeHtml(t.title.substring(0,8))}</div>`).join('')}
                        <inlineMath>{dayTodos.length > 3 ? `<div class="cell-todo-dot" style="color:var(--text-dim)">+</inlineMath>{dayTodos.length - 3}개 더</div>` : ''}
                    </div>
                </div>`;
            }

            const totalCells = firstDay + daysInMonth;
            const remaining = 7 - (totalCells % 7);
            if (remaining < 7) {
                for (let i = 1; i <= remaining; i++) {
                    html += `<div class="calendar-cell other-month"><div class="cell-date">\\({i}</div></div>`;
                }
            }

            grid.innerHTML = html;
        }

        function calendarDateClick(dateStr) {
            document.getElementById('todoDate').value = dateStr;
            switchView('list');

            const d = new Date(dateStr);
            document.getElementById('filterYear').value = d.getFullYear();
            document.getElementById('filterMonth').value = d.getMonth();
            applyFilters();
            showToast(`📅 \\){dateStr} 선택됨`);
        }

        function changeCalMonth(delta) {
            calDate.setMonth(calDate.getMonth() + delta);
            renderCalendarView();
        }

        function renderKanbanView(filtered) {
            const todoItems = filtered.filter(t => t.kanban === 'todo' && !t.completed);
            const progressItems = filtered.filter(t => t.kanban === 'progress' && !t.completed);
            const doneItems = filtered.filter(t => t.completed || t.kanban === 'done');

            document.getElementById('kanbanTodo').textContent = todoItems.length;
            document.getElementById('kanbanProgress').textContent = progressItems.length;
            document.getElementById('kanbanDone').textContent = doneItems.length;

            const renderCards = (items) => items.map(t => `
                <div class="kanban-card" onclick="openEditModal('\\({t.id}')">
                    <div class="k-title" style="border-left:3px solid \\){t.priority === 'high' ? 'var(--danger)' : t.priority === 'medium' ? 'var(--warning)' : 'var(--success)'};padding-left:8px;">\\({escapeHtml(t.title)}</div>
                    <div class="k-meta">\\){t.category} \\({t.date ? '| ' + t.date : ''}</div>
                </div>
            `).join('');

            document.getElementById('kanbanTodoItems').innerHTML = renderCards(todoItems) || '<p style="color:var(--text-dim);font-size:0.8rem;text-align:center;">비어 있음</p>';
            document.getElementById('kanbanProgressItems').innerHTML = renderCards(progressItems) || '<p style="color:var(--text-dim);font-size:0.8rem;text-align:center;">비어 있음</p>';
            document.getElementById('kanbanDoneItems').innerHTML = renderCards(doneItems) || '<p style="color:var(--text-dim);font-size:0.8rem;text-align:center;">비어 있음</p>';
        }

        function switchView(view) {
            currentView = view;
            document.querySelectorAll('.view-btn').forEach(b => b.classList.toggle('active', b.dataset.view === view));
            document.getElementById('listView').classList.toggle('active', view === 'list');
            document.getElementById('calendarView').classList.toggle('active', view === 'calendar');
            document.getElementById('kanbanView').classList.toggle('active', view === 'kanban');
            applyFilters();
        }

        function toggleDay(el) {
            const day = el.dataset.day;
            if (day === 'all') {
                document.querySelectorAll('.day-btn').forEach(b => b.classList.remove('active'));
                el.classList.add('active');
                selectedDays = ['all'];
            } else {
                document.querySelector('.day-btn[data-day="all"]').classList.remove('active');
                el.classList.toggle('active');
                selectedDays = [...document.querySelectorAll('.day-btn.active')].map(b => b.dataset.day).filter(d => d !== 'all');
                if (selectedDays.length === 0) {
                    document.querySelector('.day-btn[data-day="all"]').classList.add('active');
                    selectedDays = ['all'];
                }
            }
            applyFilters();
        }

        function togglePriority(el) {
            document.querySelectorAll('.priority-btn').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            selectedPriority = el.dataset.priority;
            applyFilters();
        }

        function toggleCategory(el) {
            document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
            selectedCategory = el.dataset.cat;
            applyFilters();
        }

        function resetFilters() {
            document.getElementById('filterYear').value = 'all';
            document.getElementById('filterMonth').value = 'all';
            document.getElementById('filterTimeStart').value = '';
            document.getElementById('filterTimeEnd').value = '';
            document.getElementById('filterStatus').value = 'all';
            document.getElementById('searchInput').value = '';
            document.getElementById('sortSelect').value = 'created-desc';

            document.querySelectorAll('.day-btn').forEach(b => b.classList.remove('active'));
            document.querySelector('.day-btn[data-day="all"]').classList.add('active');
            selectedDays = ['all'];

            document.querySelectorAll('.priority-btn').forEach(b => b.classList.remove('active'));
            document.querySelector('.priority-btn[data-priority="all"]').classList.add('active');
            selectedPriority = 'all';

            document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
            document.querySelector('.cat-btn[data-cat="all"]').classList.add('active');
            selectedCategory = 'all';

            applyFilters();
            showToast('🔄 필터가 초기화되었습니다.');
        }

        function clearCompleted() {
            const count = todos.filter(t => t.completed).length;
            if (count === 0) { showToast('완료된 항목이 없습니다.'); return; }
            if (confirm(`완료된 \\){count}개 항목을 삭제하시겠습니까?`)) {
                todos = todos.filter(t => !t.completed);
                saveTodos();
                showToast(`🗑 \\({count}개 항목 삭제됨`);
            }
        }

        function exportData() {
            const blob = new Blob([JSON.stringify(todos, null, 2)], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `todo-backup-\\){new Date().toISOString().split('T')[0]}.json`;
            a.click();
            showToast('📤 데이터가 내보내기 되었습니다.');
        }

        function importData(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = JSON.parse(e.target.result);
                    if (Array.isArray(data)) {
                        if (confirm(`\\({data.length}개 항목을 가져오시겠습니까? (기존 데이터에 추가됩니다)`)) {
                            todos = [...todos, ...data];
                            saveTodos();
                            showToast(`📥 \\){data.length}개 항목 가져오기 완료!`);
                        }
                    }
                } catch (err) {
                    showToast('⚠️ 잘못된 파일 형식입니다.');
                }
            };
            reader.readAsText(file);
            event.target.value = '';
        }

        function exportCSV() {
            let csv = '\uFEFF제목,설명,날짜,시간,마감일,우선순위,카테고리,완료여부\n';
            todos.forEach(t => {
                csv += `"\\({t.title}","\\){t.desc || ''}","\\({t.date || ''}","\\){t.time || ''}","\\({t.dueDate || ''}","\\){t.priority}","\\({t.category}","\\){t.completed ? '완료' : '미완료'}"\n`;
            });
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `todo-export-\\({new Date().toISOString().split('T')[0]}.csv`;
            a.click();
            showToast('📊 CSV 내보내기 완료!');
        }

        // Drag and drop for reordering
        let draggedId = null;
        function onDragStart(e, id) {
            draggedId = id;
            e.dataTransfer.effectAllowed = 'move';
        }
        function onDragOver(e) {
            e.preventDefault();
            e.currentTarget.classList.add('drag-over');
        }
        function onDrop(e, targetId) {
            e.preventDefault();
            e.currentTarget.classList.remove('drag-over');
            if (!draggedId || draggedId === targetId) return;
            const fromIdx = todos.findIndex(t => t.id === draggedId);
            const toIdx = todos.findIndex(t => t.id === targetId);
            if (fromIdx < 0 || toIdx < 0) return;
            const [item] = todos.splice(fromIdx, 1);
            todos.splice(toIdx, 0, item);
            saveTodos();
        }

        // Pomodoro Timer
        function updatePomodoroDisplay() {
            const m = Math.floor(pomodoroSeconds / 60).toString().padStart(2, '0');
            const s = (pomodoroSeconds % 60).toString().padStart(2, '0');
            document.getElementById('pomodoroDisplay').textContent = `\\){m}:\\({s}`;
        }

        function startPomodoro() {
            const btn = document.getElementById('pomodoroStartBtn');
            if (pomodoroInterval) {
                clearInterval(pomodoroInterval);
                pomodoroInterval = null;
                btn.textContent = '▶ 시작';
                btn.classList.remove('active-timer');
                return;
            }
            btn.textContent = '⏸ 일시정지';
            btn.classList.add('active-timer');
            pomodoroInterval = setInterval(() => {
                pomodoroSeconds--;
                updatePomodoroDisplay();
                if (pomodoroSeconds <= 0) {
                    clearInterval(pomodoroInterval);
                    pomodoroInterval = null;
                    btn.textContent = '▶ 시작';
                    btn.classList.remove('active-timer');
                    showToast('🍅 포모도로 완료! 잘하셨습니다!');
                    if (Notification.permission === 'granted') {
                        new Notification('🍅 포모도로 완료!', { body: '잠시 휴식하세요!' });
                    }
                    pomodoroSeconds = 2 * 0;
                    updatePomodoroDisplay();
                }
            }, 1000);
        }

        function resetPomodoro() {
            clearInterval(pomodoroInterval);
            pomodoroInterval = null;
            pomodoroSeconds = 2 * 0;
            updatePomodoroDisplay();
            document.getElementById('pomodoroStartBtn').textContent = '▶ 시작';
            document.getElementById('pomodoroStartBtn').classList.remove('active-timer');
        }

        function setPomodoro(minutes) {
            clearInterval(pomodoroInterval);
            pomodoroInterval = null;
            pomodoroSeconds = minute * 0;
            updatePomodoroDisplay();
            document.getElementById('pomodoroStartBtn').textContent = '▶ 시작';
            document.getElementById('pomodoroStartBtn').classList.remove('active-timer');
        }

        // Notifications
        function checkNotifications() {
            if ('Notification' in window && Notification.permission === 'default') {
                Notification.requestPermission();
            }
            const now = new Date();
            todos.forEach(t => {
                if (t.completed) return;
                if (t.dueDate && t.dueTime) {
                    const due = new Date(t.dueDate + 'T' + t.dueTime);
                    const diff = due - now;
                    if (diff > 0 && diff <= 1 *  * 000 && !t._notified) {
                        t._notified = true;
                        showToast(`⏰ "\\){t.title}" 마감 15분 전!`);
                        if (Notification.permission === 'granted') {
                            new Notification('⏰ 마감 임박!', { body: `"\\({t.title}" 마감까지 15분 남았습니다.` });
                        }
                    }
                }
            });
        }

        // Theme
        function toggleTheme() {
            document.body.classList.toggle('light');
            localStorage.setItem('todoTheme', document.body.classList.contains('light') ? 'light' : 'dark');
        }

        if (localStorage.getItem('todoTheme') === 'light') {
            document.body.classList.add('light');
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function showToast(message) {
            const existing = document.querySelector('.toast');
            if (existing) existing.remove();
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeEditModal();
            if (e.ctrlKey && e.key === 'n') {
                e.preventDefault();
                document.getElementById('todoTitle').focus();
            }
        });

        // Close modal on overlay click
        document.getElementById('editModal').addEventListener('click', (e) => {
            if (e.target === document.getElementById('editModal')) closeEditModal();
        });

        init();
    </script>
</body>
</html>
