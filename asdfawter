function fmt(n, d = 2) {
    if (n === null || n === undefined || isNaN(n)) return 'N/A';
    if (Number.isInteger(n) && Math.abs(n) < 1e15) return n.toLocaleString();
    return parseFloat(n.toFixed(d)).toLocaleString(undefined, { maximumFractionDigits: d });
}

function isNumeric(v) {
    if (v === null || v === undefined || v === '') return false;
    return !isNaN(Number(v));
}

function inferType(values) {
    let numCount = 0, dateCount = 0, total = 0;
    for (const v of values) {
        if (v === null || v === undefined || v === '') continue;
        total++;
        if (isNumeric(v)) numCount++;
        else if (!isNaN(Date.parse(v)) && v.length > 4) dateCount++;
    }
    if (total === 0) return 'text';
    if (numCount / total > 0.8) return 'numeric';
    if (dateCount / total > 0.8) return 'date';
    return 'text';
}

function getNumericValues(data, col) {
    return data.map(r => parseFloat(r[col])).filter(v => !isNaN(v));
}

function mean(arr) { return arr.length ? arr.reduce((a, b) => a + b, 0) / arr.length : 0; }

function median(arr) {
    if (!arr.length) return 0;
    const s = [...arr].sort((a, b) => a - b);
    const m = Math.floor(s.length / 2);
    return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2;
}

function stddev(arr) {
    const m = mean(arr);
    return Math.sqrt(arr.reduce((s, v) => s + (v - m) ** 2, 0) / arr.length);
}

function q1(arr) {
    const s = [...arr].sort((a, b) => a - b);
    return median(s.slice(0, Math.floor(s.length / 2)));
}

function q3(arr) {
    const s = [...arr].sort((a, b) => a - b);
    return median(s.slice(Math.ceil(s.length / 2)));
}

function skewness(arr) {
    const m = mean(arr), sd = stddev(arr), n = arr.length;
    if (sd === 0 || n < 3) return 0;
