    c.classList.remove('hidden');
    c.innerHTML = state.datasets.map((ds, i) =>
        `<div class="dataset-tab \\){i === state.activeIndex ? 'active' : ''}" onclick="switchDataset(\\({i})">
            \\){ds.name}
            <button class="remove-ds" onclick="event.stopPropagation();removeDataset(\\({i})">&times;</button>
        </div>`
    ).join('');
}

function switchDataset(idx) {
    state.activeIndex = idx;
    state.filters = [];
    state.sortCol = null;
    state.tablePage = 0;
    renderFilters();
    refreshAll();
}

function removeDataset(idx) {
    state.datasets.splice(idx, 1);
    if (state.datasets.length === 0) {
        state.activeIndex = -1;
        hideAnalysis();
    } else {
        state.activeIndex = Math.min(idx, state.datasets.length - 1);
        state.filters = [];
        state.sortCol = null;
        state.tablePage = 0;
    }
    refreshAll();
}

