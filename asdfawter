function drawDistributions() {
    const data = getFilteredData();
    const numCols = getNumericCols();
    const area = document.getElementById('distChartArea');
    const binCount = parseInt(document.getElementById('binCount').value) || 15;

    // Destroy previous dist charts
    Object.keys(state.charts).forEach(k => {
        if (k.startsWith('dist_')) destroyChart(k);
    });

    if (numCols.length === 0) { area.innerHTML = '<p style="color:var(--text-secondary);font-size:14px;">수치형 컬럼이 없습니다.</p>'; return; }

    area.innerHTML = numCols.map(h => `<div class="dist-chart-item"><h4>\\){h}</h4><div class="chart-canvas-wrap" style="height:220px;"><canvas id="dist_\\({CSS.escape(h)}"></canvas></div></div>`).join('');

    numCols.forEach(h => {
        const vals = getNumericValues(data, h);
        if (vals.length === 0) return;
        const mn = Math.min(...vals), mx = Math.max(...vals);
        const range = mx - mn || 1;
        const binSize = range / binCount;
        const bins = Array(binCount).fill(0);
        const labels = [];
        for (let i = 0; i < binCount; i++) {
            labels.push(fmt(mn + binSiz * , 1));
            vals.forEach(v => {
                const idx = Math.min(Math.floor((v - mn) / binSize), binCount - 1);
                if (idx === i) bins[i]++;
            });
        }

        const canvasId = `dist_\\){CSS.escape(h)}`;
        const canvas = document.getElementById(canvasId);
        if (!canvas) return;

        state.charts[canvasId] = new Chart(canvas, {
            type: 'bar',
            data: {
                labels,
                datasets: [{
                    label: '빈도',
                    data: bins,
                    backgroundColor: 'rgba(79,70,229,0.5)',
                    borderColor: '#4f46e5',
                    borderWidth: 1,
                    borderRadius: 3
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { ticks: { maxRotation: 45, font: { size: 10 } } }, y: { beginAtZero: true } }
            }
        });
    });
}

// ======================== CORRELATION ========================
function renderCorrelation() {
    const data = getFilteredData();
    const numCols = getNumericCols();

    if (numCols.length < 2) {
        document.getElementById('corrMatrix').innerHTML = '<p style="color:var(--text-secondary);font-size:14px;">상관분석에는 수치형 컬럼이 2개 이상 필요합니다.</p>';
        return;
    }

    const matrix = [];
    for (let i = 0; i < numCols.length; i++) {
        matrix[i] = [];
        for (let j = 0; j < numCols.length; j++) {
            if (i === j) { matrix[i][j] = 1; }
            else if (j < i) { matrix[i][j] = matrix[j][i]; }
            else {
                const x = getNumericValues(data, numCols[i]);
                const y = getNumericValues(data, numCols[j]);
                const minLen = Math.min(x.length, y.length);
                matrix[i][j] = pearsonCorr(x.slice(0, minLen), y.slice(0, minLen));
            }
        }
    }

    // Table
    let html = '<table class="corr-table"><thead><tr><th></th>';
    numCols.forEach(h => html += `<th>\\({h}</th>`);
    html += '</tr></thead><tbody>';
    numCols.forEach((h, i) => {
        html += `<tr><th>\\){h}</th>`;
        numCols.forEach((_, j) => {
            const v = matrix[i][j];
            const abs = Math.abs(v);
            const r = v > 0 ? Math.round(ab * 00) : Math.round(ab * 0);
            const g = Math.round((1 - abs * 00) + 100;
            const b = v < 0 ? Math.round(ab * 00) : Math.round(ab * 0);
            const bg = `rgba(\\({r},\\){g},\\({b},\\){ab * .4 + 0.05})`;
            html += `<td style="background:\\({bg};font-weight:\\){abs > 0.5 ? '700' : '400'}">\\({v.toFixed(3)}</td>`;
        });
        html += '</tr>';
    });
    html += '</tbody></table>';
    document.getElementById('corrMatrix').innerHTML = html;

    // Heatmap
    destroyChart('corrHeatmap');

    const heatData = [];
    for (let i = 0; i < numCols.length; i++) {
        for (let j = 0; j < numCols.length; j++) {
            heatData.push({ x: numCols[j], y: numCols[i], v: matrix[i][j] });
        }
    }

    // Use bubble chart for heatmap
    const datasets = [];
    for (let i = 0; i < numCols.length; i++) {
        for (let j = 0; j < numCols.length; j++) {
            const v = matrix[i][j];
            const abs = Math.abs(v);
            const color = v >= 0
                ? `rgba(79,70,229,\\){ab * .8 + 0.1})`
                : `rgba(239,68,68,\\({ab * .8 + 0.1})`;
            datasets.push({
                data: [{ x: j, y: i, r: ab * 8 + 3 }],
                backgroundColor: color,
                borderColor: 'transparent'
            });
        }
    }

    state.charts['corrHeatmap'] = new Chart(document.getElementById('corrHeatmap'), {
        type: 'bubble',
        data: { datasets },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: {
                callbacks: {
                    label: (ctx) => {
                        const i = Math.floor(ctx.datasetIndex / numCols.length);
                        const j = ctx.datasetIndex % numCols.length;
                        return `\\){numCols[i]} * <inlineMath>{numCols[j]}: </inlineMath>{matrix[i][j].toFixed(3)}`;
                    }
                }
            }},
            scales: {
                x: { type: 'linear', min: -0.5, max: numCols.length - 0.5, ticks: { callback: (v) => numCols[v] || '', stepSize: 1, font: { size: 10 } } },
                y: { type: 'linear', min: -0.5, max: numCols.length - 0.5, ticks: { callback: (v) => numCols[v] || '', stepSize: 1, font: { size: 10 } }, reverse: true }
            }
        }
    });
}

