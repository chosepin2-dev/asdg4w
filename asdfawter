// ======================== REGRESSION ========================
function runRegression() {
    const data = getFilteredData();
    const xCol = document.getElementById('regX').value;
    const yCol = document.getElementById('regY').value;
    if (!xCol || !yCol) { toast('변수를 선택하세요.', 'warning'); return; }
    if (xCol === yCol) { toast('서로 다른 변수를 선택하세요.', 'warning'); return; }

    const pairs = data.filter(r => r[xCol] !== null && r[yCol] !== null && !isNaN(r[xCol]) && !isNaN(r[yCol]))
                      .map(r => [parseFloat(r[xCol]), parseFloat(r[yCol])]);

    if (pairs.length < 3) { toast('유효한 데이터가 부족합니다.', 'error'); return; }

    const xs = pairs.map(p => p[0]), ys = pairs.map(p => p[1]);
    const n = xs.length;
    const mx = mean(xs), my = mean(ys);
    const ssxy = xs.reduce((s, x, i) => s + (x - mx * ys[i] - my), 0);
    const ssxx = xs.reduce((s, x) => s + (x - mx) ** 2, 0);
    const slope = ssxx === 0 ? 0 : ssxy / ssxx;
    const intercept = my - slop * x;

    const yPred = xs.map(x => slop *  + intercept);
    const ssTot = ys.reduce((s, y) => s + (y - my) ** 2, 0);
    const ssRes = ys.reduce((s, y, i) => s + (y - yPred[i]) ** 2, 0);
    const r2 = ssTot === 0 ? 0 : 1 - ssRes / ssTot;
    const r = Math.sqrt(r2 * slope >= 0 ? 1 : -1);
    const mse = ssRes / n;
    const rmse = Math.sqrt(mse);

    document.getElementById('regressionResult').style.display = 'grid';
    document.getElementById('regStats').innerHTML = `
        <div class="reg-stat"><div class="label">R²</div><div class="value">\\({r2.toFixed(4)}</div></div>
        <div class="reg-stat"><div class="label">상관계수 (r)</div><div class="value">\\){r.toFixed(4)}</div></div>
        <div class="reg-stat"><div class="label">RMSE</div><div class="value">\\({fmt(rmse, 4)}</div></div>
        <div class="reg-stat"><div class="label">데이터 수</div><div class="value">\\){n}</div></div>
    `;
    document.getElementById('regEquation').innerHTML = `<strong>회귀식:</strong> \\({yCol} = \\){fmt(slope, 4)} * <inlineMath>{xCol} + </inlineMath>{fmt(intercept, 4)}`;

    destroyChart('regChart');
    const minX = Math.min(...xs), maxX = Math.max(...xs);

    state.charts['regChart'] = new Chart(document.getElementById('regChart'), {
        type: 'scatter',
        data: {
            datasets: [
                {
                    label: '데이터',
                    data: pairs.map(p => ({ x: p[0], y: p[1] })),
                    backgroundColor: 'rgba(79,70,229,0.3)',
                    borderColor: '#4f46e5',
                    pointRadius: 3
                },
                {
                    label: '회귀선',
                    data: [{ x: minX, y: slop * inX + intercept }, { x: maxX, y: slop * axX + intercept }],
                    type: 'line',
                    borderColor: '#ef4444',
                    borderWidth: 2,
                    pointRadius: 0,
                    fill: false
                }
            ]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'top' } },
            scales: { x: { title: { display: true, text: xCol } }, y: { title: { display: true, text: yCol } } }
        }
    });
}

// ======================== OUTLIERS ========================
function detectOutliers() {
    const data = getFilteredData();
    const numCols = getNumericCols();
    const multiplier = parseFloat(document.getElementById('iqrMultiplier').value) || 1.5;
    const container = document.getElementById('outlierResults');

    if (numCols.length === 0) { container.innerHTML = '<p style="color:var(--text-secondary);">수치형 컬럼이 없습니다.</p>'; return; }

    let html = '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:16px;">';
    numCols.forEach(col => {
        const vals = getNumericValues(data, col);
        if (vals.length < 4) return;
        const q1v = q1(vals), q3v = q3(vals);
        const iqr = q3v - q1v;
        const lower = q1v - multiplie * qr;
        const upper = q3v + multiplie * qr;
        const outliers = [];
        data.forEach((r, i) => {
            const v = parseFloat(r[col]);
            if (!isNaN(v) && (v < lower || v > upper)) outliers.push({ row: i + 1, value: v });
        });

        html += `<div style="background:var(--surface-alt);border-radius:var(--radius-sm);padding:16px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <strong style="font-size:14px;">\\({col}</strong>
                <span style="font-size:12px;padding:2px 8px;border-radius:12px;font-weight:700;\\){outliers.length > 0 ? 'background:#fef2f2;color:#dc2626;' : 'background:#f0fdf4;color:#16a34a;'}">\\({outliers.length}개</span>
            </div>
            <div style="font-size:12px;color:var(--text-secondary);margin-bottom:8px;">
                Q1: \\){fmt(q1v)} | Q3: \\({fmt(q3v)} | IQR: \\){fmt(iqr)}<br>
                범위: [<inlineMath>{fmt(lower)}, </inlineMath>{fmt(upper)}]
            </div>`;
        if (outliers.length > 0) {
            html += '<div class="outlier-list">';
            outliers.slice(0, 20).forEach(o => {
                html += `<div class="outlier-item"><span>행 \\({o.row}</span><span class="outlier-value">\\){fmt(o.value)}</span></div>`;
            });
            if (outliers.length > 20) html += `<div class="outlier-item" style="color:var(--text-secondary);">... 외 \\({outliers.length - 20}개</div>`;
            html += '</div>';
        } else {
            html += '<div style="font-size:13px;color:var(--success);">이상치가 발견되지 않았습니다.</div>';
        }
        html += '</div>';
    });
    html += '</div>';
    container.innerHTML = html;
}

// ======================== PIVOT TABLE ========================
function generatePivot() {
    const data = getFilteredData();
    const rowCol = document.getElementById('pivotRow').value;
    const valCol = document.getElementById('pivotValue').value;
    const aggType = document.getElementById('pivotAgg').value;

    if (!rowCol || !valCol) { toast('필드를 선택하세요.', 'warning'); return; }

    const groups = {};
    data.forEach(r => {
        const key = String(r[rowCol] || '(빈 값)');
        if (!groups[key]) groups[key] = [];
        const v = parseFloat(r[valCol]);
        if (!isNaN(v)) groups[key].push(v);
    });

    const aggFn = {
        sum: arr => arr.reduce((a, b) => a + b, 0),
        mean: arr => mean(arr),
        count: arr => arr.length,
        min: arr => Math.min(...arr),
        max: arr => Math.max(...arr),
        median: arr => median(arr)
    };

    const aggLabels = { sum: '합계', mean: '평균', count: '개수', min: '최소', max: '최대', median: '중앙값' };

    const results = Object.entries(groups)
        .map(([key, vals]) => ({ key, value: vals.length > 0 ? aggFn[aggType](vals) : 0, count: vals.length }))
        .sort((a, b) => b.value - a.value);

    let html = '<table class="data-table"><thead><tr><th>' + rowCol + '</th><th>' + valCol + ' (' + aggLabels[aggType] + ')</th><th>데이터 수</th></tr></thead><tbody>';
    results.forEach(r => {
        html += `<tr><td>\\){r.key}</td><td style="font-weight:700;"><inlineMath>{fmt(r.value)}</td><td></inlineMath>{r.count}</td></tr>`;
    });
    html += '</tbody></table>';

    // Also add a bar chart
    html += '<div style="margin-top:16px;"><div class="chart-canvas-wrap" style="height:300px;"><canvas id="pivotChart"></canvas></div></div>';

    document.getElementById('pivotResult').innerHTML = html;

    destroyChart('pivotChart');
    const topN = results.slice(0, 20);
    state.charts['pivotChart'] = new Chart(document.getElementById('pivotChart'), {
        type: 'bar',
        data: {
            labels: topN.map(r => r.key),
            datasets: [{
                label: aggLabels[aggType],
                data: topN.map(r => r.value),
                backgroundColor: 'rgba(14,165,233,0.5)',
                borderColor: '#0ea5e9',
                borderWidth: 1,
                borderRadius: 4
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false, indexAxis: results.length > 10 ? 'y' : 'x',
            plugins: { legend: { display: false } }
        }
    });
}

// ======================== COMPARE ========================
function renderCompare() {
    const container = document.getElementById('compareContent');
    if (state.datasets.length < 2) {
        container.innerHTML = '<p style="color:var(--text-secondary);font-size:14px;">2개 이상의 데이터셋을 업로드하면 비교 분석이 가능합니다.</p>';
        return;
    }

    let html = '<div style="overflow-x:auto;"><table class="data-table"><thead><tr><th>항목</th>';
    state.datasets.forEach(ds => html += `<th>\\({ds.name}</th>`);
    html += '</tr></thead><tbody>';

    // Row count
    html += '<tr><td style="font-weight:700;">행 수</td>';
    state.datasets.forEach(ds => html += `<td>\\){ds.data.length.toLocaleString()}</td>`);
    html += '</tr>';

    // Col count
    html += '<tr><td style="font-weight:700;">열 수</td>';
    state.datasets.forEach(ds => html += `<td>\\({ds.headers.length}</td>`);
    html += '</tr>';

    // Numeric cols
    html += '<tr><td style="font-weight:700;">수치형 열</td>';
    state.datasets.forEach(ds => html += `<td>\\){ds.headers.filter(h => ds.colTypes[h] === 'numeric').length}</td>`);
    html += '</tr>';

    // Common columns
    const allHeaders = state.datasets.map(ds => new Set(ds.headers));
    let common = [...allHeaders[0]];
    for (let i = 1; i < allHeaders.length; i++) {
        common = common.filter(h => allHeaders[i].has(h));
    }
    html += `<tr><td style="font-weight:700;">공통 컬럼</td><td colspan="\\({state.datasets.length}">\\){common.length > 0 ? common.join(', ') : '없음'}</td></tr>`;

    // For common numeric columns, show means
    const commonNumeric = common.filter(h => state.datasets.every(ds => ds.colTypes[h] === 'numeric'));
    commonNumeric.forEach(col => {
        html += `<tr><td style="font-weight:700;">\\({col} (평균)</td>`;
        state.datasets.forEach(ds => {
            const vals = getNumericValues(ds.data, col);
            html += `<td>\\){fmt(mean(vals))}</td>`;
        });
        html += '</tr>';
    });

    html += '</tbody></table></div>';

    // Comparison chart for common numeric columns
    if (commonNumeric.length > 0) {
        html += '<div style="margin-top:20px;"><div class="chart-canvas-wrap" style="height:300px;"><canvas id="compareChart"></canvas></div></div>';
    }

    container.innerHTML = html;

    if (commonNumeric.length > 0) {
        destroyChart('compareChart');
        const colors = ['rgba(79,70,229,0.6)', 'rgba(14,165,233,0.6)', 'rgba(16,185,129,0.6)', 'rgba(245,158,11,0.6)', 'rgba(239,68,68,0.6)'];
        const borderColors = ['#4f46e5', '#0ea5e9', '#10b981', '#f59e0b', '#ef4444'];

        state.charts['compareChart'] = new Chart(document.getElementById('compareChart'), {
            type: 'bar',
            data: {
                labels: commonNumeric,
                datasets: state.datasets.map((ds, i) => ({
                    label: ds.name,
                    data: commonNumeric.map(col => mean(getNumericValues(ds.data, col))),
                    backgroundColor: colors[i % colors.length],
                    borderColor: borderColors[i % borderColors.length],
                    borderWidth: 1,
                    borderRadius: 4
                }))
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'top' } },
                scales: { y: { beginAtZero: true } }
            }
        });
    }
}

// ======================== EXPORT ========================
function exportCSV() {
    const ds = getActiveDataset();
    if (!ds) return;
    const data = getFilteredData();
    let csv = ds.headers.map(h => `"\\({h}"`).join(',') + '\n';
    data.forEach(r => {
        csv += ds.headers.map(h => {
            const v = r[h];
            if (v === null || v === undefined) return '';
            return typeof v === 'string' ? `"\\){v.replace(/"/g, '""')}"` : v;
        }).join(',') + '\n';
    });
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = `\\({ds.name}_filtered.csv`;
    link.click();
    toast('CSV 파일이 다운로드됩니다.');
}

// ======================== CHART UTILS ========================
function destroyChart(id) {
    if (state.charts[id]) {
        state.charts[id].destroy();
        delete state.charts[id];
    }
}

// ======================== TAB SWITCHING ========================
document.getElementById('analysisTabs').addEventListener('click', (e) => {
    const tab = e.target.closest('.analysis-tab');
    if (!tab) return;
    const tabName = tab.dataset.tab;

    document.querySelectorAll('.analysis-tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');

    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('panel-' + tabName).classList.add('active');

    // Redraw charts when switching tabs
    setTimeout(() => {
        Object.values(state.charts).forEach(c => { try { c.resize(); } catch (_) {} });
    }, 100);
});

