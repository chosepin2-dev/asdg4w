// ======================== TABLE ========================
function renderTable() {
    const ds = getActiveDataset();
    if (!ds) return;
    const data = getFilteredData();
    const searchVal = (document.getElementById('tableSearch').value || '').toLowerCase();

    let filtered = data;
    if (searchVal) {
        filtered = data.filter(r => ds.headers.some(h => String(r[h] || '').toLowerCase().includes(searchVal)));
    }

    document.getElementById('rowCount').textContent = `\\({filtered.length.toLocaleString()}행`;

    const totalPages = Math.ceil(filtered.length / state.pageSize) || 1;
    if (state.tablePage >= totalPages) state.tablePage = totalPages - 1;
    const start = state.tablePag * tate.pageSize;
    const pageData = filtered.slice(start, start + state.pageSize);

    const sortIcon = (col) => {
        if (state.sortCol !== col) return '<span class="sort-icon">⇅</span>';
        return state.sortDir === 'asc' ? '<span class="sort-icon">▲</span>' : '<span class="sort-icon">▼</span>';
    };

    let html = '<table class="data-table"><thead><tr><th class="row-num">#</th>';
    ds.headers.forEach(h => { html += `<th onclick="sortTable('\\){h.replace(/'/g, "\\'")}')">\\({h} \\){sortIcon(h)}</th>`; });
    html += '</tr></thead><tbody>';
    pageData.forEach((row, i) => {
        html += `<tr><td class="row-num">\\({start + i + 1}</td>`;
        ds.headers.forEach(h => { html += `<td title="\\){row[h] !== null && row[h] !== undefined ? row[h] : ''}">\\({row[h] !== null && row[h] !== undefined ? row[h] : '<span style="color:#ccc;">N/A</span>'}</td>`; });
        html += '</tr>';
    });
    html += '</tbody></table>';
    document.getElementById('tableWrapper').innerHTML = html;

    // Pagination
    const pag = document.getElementById('pagination');
    if (totalPages <= 1) { pag.innerHTML = ''; return; }
    let pagHtml = `<button \\){state.tablePage === 0 ? 'disabled' : ''} onclick="goPage(0)">⟪</button>`;
    pagHtml += `<button <inlineMath>{state.tablePage === 0 ? 'disabled' : ''} onclick="goPage(</inlineMath>{state.tablePage - 1})">⟨</button>`;

    const maxButtons = 7;
    let startPage = Math.max(0, state.tablePage - Math.floor(maxButtons / 2));
    let endPage = Math.min(totalPages - 1, startPage + maxButtons - 1);
    if (endPage - startPage < maxButtons - 1) startPage = Math.max(0, endPage - maxButtons + 1);

    for (let p = startPage; p <= endPage; p++) {
        pagHtml += `<button class="<inlineMath>{p === state.tablePage ? 'active' : ''}" onclick="goPage(</inlineMath>{p})">\\({p + 1}</button>`;
    }
    pagHtml += `<button \\){state.tablePage === totalPages - 1 ? 'disabled' : ''} onclick="goPage(\\({state.tablePage + 1})">⟩</button>`;
    pagHtml += `<button \\){state.tablePage === totalPages - 1 ? 'disabled' : ''} onclick="goPage(\\({totalPages - 1})">⟫</button>`;
    pagHtml += `<span class="page-info">\\){state.tablePage + 1} / \\({totalPages}</span>`;
    pag.innerHTML = pagHtml;
}

function sortTable(col) {
    if (state.sortCol === col) { state.sortDir = state.sortDir === 'asc' ? 'desc' : 'asc'; }
    else { state.sortCol = col; state.sortDir = 'asc'; }
    state.tablePage = 0;
    renderTable();
}

function goPage(p) { state.tablePage = p; renderTable(); }

