}

function removeFilter(idx) {
    state.filters.splice(idx, 1);
    state.tablePage = 0;
    renderFilters();
    refreshAnalysis();
}

function clearAllFilters() {
    state.filters = [];
    state.tablePage = 0;
    renderFilters();
    refreshAnalysis();
}

