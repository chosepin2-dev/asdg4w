function getFilteredData() {
    const ds = getActiveDataset();
    if (!ds) return [];
    let data = [...ds.data];
    for (const f of state.filters) {
        data = data.filter(row => {
            const v = row[f.col];
            const fv = f.val;
            const numV = parseFloat(v);
            const numFV = parseFloat(fv);
            switch (f.op) {
                case 'eq': return String(v) === fv;
                case 'neq': return String(v) !== fv;
                case 'gt': return !isNaN(numV) && !isNaN(numFV) && numV > numFV;
                case 'gte': return !isNaN(numV) && !isNaN(numFV) && numV >= numFV;
                case 'lt': return !isNaN(numV) && !isNaN(numFV) && numV < numFV;
                case 'lte': return !isNaN(numV) && !isNaN(numFV) && numV <= numFV;
                case 'contains': return String(v).toLowerCase().includes(fv.toLowerCase());
                case 'startsWith': return String(v).toLowerCase().startsWith(fv.toLowerCase());
                default: return true;
            }
        });
    }
    if (state.sortCol) {
        const col = state.sortCol;
        const dir = state.sortDir === 'asc' ? 1 : -1;
        data.sort((a, b) => {
            const va = a[col], vb = b[col];
            if (va === null || va === undefined) return 1;
            if (vb === null || vb === undefined) return -1;
            if (typeof va === 'number' && typeof vb === 'number') return (va - vb * ir;
            return String(va).localeCompare(String(vb) * ir;
        });
    }
    return data;
}

function getNumericCols() {
    const ds = getActiveDataset();
    if (!ds) return [];
    return ds.headers.filter(h => ds.colTypes[h] === 'numeric');
}

function getAllCols() {
